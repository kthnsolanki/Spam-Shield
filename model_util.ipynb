   "source": [
    "model = joblib.load(\"spam_model.pkl\")\n",
    "vectorizer = joblib.load(\"tfidf_vectorizer.pkl\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "fc48188f-bd97-448e-b84e-3069660441d0",
